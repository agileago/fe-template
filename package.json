{
  "name": "starter",
  "version": "0.0.0",
  "description": "vite项目模板",
  "type": "module",
  "scripts": {
    "api": "tsg",
    "build": "vite build",
    "build:uat": "vite build --mode uat",
    "chrome": "open -n /Applications/Google\\ Chrome.app/ --args --disable-web-security  --user-data-dir=$HOME/MyChromeDevUserData/",
    "coverage": "vitest run --coverage",
    "dev": "vite",
    "dev:uat": "vite --mode uat",
    "format": "prettier --write .",
    "lint": "eslint --fix .",
    "prepare": "simple-git-hooks",
    "preview": "vite preview",
    "test": "vitest --passWithNoTests",
    "type:check": "tsgo --noEmit"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm exec lint-staged",
    "commit-msg": "pnpm exec commitlint -e $1"
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{js,css,scss,html,json}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@vueuse/core": "^14.2.1",
    "axios": "^1.14.0",
    "dayjs": "^1.11.20",
    "es-toolkit": "^1.45.1",
    "go-try": "^3.0.2",
    "pinia": "^3.0.4",
    "rattail": "^1.7.0",
    "ts-essentials": "^10.1.1",
    "ts-pattern": "^5.9.0",
    "tslib": "^2.8.1",
    "vue": "^3.5.31",
    "vue-better-props": "^0.0.6",
    "vue-router": "^5.0.4"
  },
  "devDependencies": {
    "@babel/plugin-transform-unicode-property-regex": "^7.28.6",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@configurajs/eslint": "^0.1.2",
    "@configurajs/prettier": "^0.1.4",
    "@typescript/native-preview": "7.0.0-dev.20260401.1",
    "@vitejs/plugin-legacy": "^8.0.1",
    "@vitejs/plugin-vue-jsx": "^5.1.5",
    "@vue3-oop/tailwind-preset": "^2.0.1",
    "@vue3-oop/ts-gear": "^5.0.7",
    "browserslist-to-esbuild": "^2.1.1",
    "eslint": "^9.39.4",
    "happy-dom": "^20.8.9",
    "less": "^4.6.4",
    "lint-staged": "^16.4.0",
    "postcss": "^8.5.8",
    "postcss-preset-env": "^11.2.0",
    "prettier": "^3.8.1",
    "prettier-plugin-packagejson": "^3.0.2",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "sass": "^1.99.0",
    "simple-git-hooks": "^2.13.1",
    "tailwindcss": "^3.4.19",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "vite-plugin-babel": "^1.6.0",
    "vitest": "^4.1.2"
  }
}
